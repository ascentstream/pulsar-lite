class Test${dispatcher_type}EdgeCases:
    """Test edge cases"""

    def test_no_messages(self, client: pulsar.Client):
        """Test consumer behavior with no messages"""
        consumer = client.subscribe(
            TEST_TOPIC,
            f"{TEST_SUBSCRIPTION}-empty",
            consumer_type=pulsar.ConsumerType.${consumer_type}
        )

        # Try to receive with timeout
        with pytest.raises(Exception):
            consumer.receive(timeout_millis=1000)

        consumer.close()

    def test_large_messages(
        self, client: pulsar.Client, producer: pulsar.Producer
    ):
        """Test with large messages"""
        large_payload = b"x" * (1024 * 1024)  # 1MB

        consumer = client.subscribe(
            TEST_TOPIC,
            f"{TEST_SUBSCRIPTION}-large",
            consumer_type=pulsar.ConsumerType.${consumer_type}
        )

        producer.send(large_payload)
        msg = consumer.receive(timeout_millis=5000)
        assert len(msg.data()) == len(large_payload)

        consumer.acknowledge(msg)
        consumer.close()

    def test_rapid_connect_disconnect(self, client: pulsar.Client):
        """Test rapid consumer connect/disconnect"""
        for i in range(10):
            consumer = client.subscribe(
                TEST_TOPIC,
                f"{TEST_SUBSCRIPTION}-rapid",
                consumer_type=pulsar.ConsumerType.${consumer_type}
            )
            consumer.close()


