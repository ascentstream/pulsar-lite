# ========================================
# Basic Tests
# ========================================

class Test${dispatcher_type}DispatcherBasic:
    """Basic functionality tests"""

    def test_single_consumer_receives_messages(
        self, client: pulsar.Client, producer: pulsar.Producer
    ):
        """Test that single consumer receives all messages"""
        consumer = client.subscribe(
            TEST_TOPIC,
            TEST_SUBSCRIPTION,
            consumer_type=pulsar.ConsumerType.${consumer_type}
        )

        # Send messages
        for i in range(10):
            producer.send(f"message-{i}".encode())

        # Receive and verify
        received = []
        for _ in range(10):
            msg = consumer.receive(timeout_millis=5000)
            received.append(msg.data().decode())
            consumer.acknowledge(msg)

        consumer.close()

        assert len(received) == 10
        for i in range(10):
            assert f"message-{i}" in received

    def test_multiple_consumers(
        self, client: pulsar.Client, producer: pulsar.Producer
    ):
        """Test with multiple consumers"""
        consumers = []
        for i in range(NUM_CONSUMERS):
            c = client.subscribe(
                TEST_TOPIC,
                f"{TEST_SUBSCRIPTION}-multi",
                consumer_type=pulsar.ConsumerType.${consumer_type},
                consumer_name=f"consumer-{i}"
            )
            consumers.append(c)

        # Send messages
        for i in range(NUM_MESSAGES):
            producer.send(f"message-{i}".encode())

        # Collect received messages
        all_received = []
        for consumer in consumers:
            try:
                while True:
                    msg = consumer.receive(timeout_millis=1000)
                    all_received.append(msg.data().decode())
                    consumer.acknowledge(msg)
            except Exception:
                pass

        for c in consumers:
            c.close()

        # Verify all messages received
        assert len(all_received) == NUM_MESSAGES


