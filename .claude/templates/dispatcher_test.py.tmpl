# ========================================
# Concurrency Tests
# ========================================

class Test${dispatcher_type}Concurrency:
    """Test concurrent access"""

    def test_concurrent_producers(
        self, client: pulsar.Client
    ):
        """Test multiple producers sending concurrently"""
        def produce(producer_id: int, num_messages: int):
            p = client.create_producer(TEST_TOPIC)
            for i in range(num_messages):
                p.send(f"producer-{producer_id}-msg-{i}".encode())
            p.close()

        with ThreadPoolExecutor(max_workers=5) as executor:
            futures = [
                executor.submit(produce, i, 20)
                for i in range(5)
            ]
            for f in futures:
                f.result()

        # Verify all messages received
        consumer = client.subscribe(
            TEST_TOPIC,
            f"{TEST_SUBSCRIPTION}-concurrent",
            consumer_type=pulsar.ConsumerType.${consumer_type}
        )

        count = 0
        try:
            while True:
                consumer.receive(timeout_millis=1000)
                count += 1
        except Exception:
            pass

        consumer.close()
        assert count == 100  # 5 producers * 20 messages

    def test_concurrent_consumers(
        self, client: pulsar.Client, producer: pulsar.Producer
    ):
        """Test multiple consumers receiving concurrently"""
        pass


