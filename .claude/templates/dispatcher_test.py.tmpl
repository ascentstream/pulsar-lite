    def test_throughput(self, client: pulsar.Client, producer: pulsar.Producer):
        """Test message throughput"""
        import time

        consumer = client.subscribe(
            TEST_TOPIC,
            f"{TEST_SUBSCRIPTION}-perf",
            consumer_type=pulsar.ConsumerType.${consumer_type}
        )

        # Send messages
        num_messages = 10000
        start_time = time.time()

        for i in range(num_messages):
            producer.send(f"perf-{i}".encode())

        send_time = time.time() - start_time

        # Receive messages
        start_time = time.time()
        received = 0
        try:
            while received < num_messages:
                consumer.receive(timeout_millis=5000)
                received += 1
        except Exception:
            pass

        receive_time = time.time() - start_time

        consumer.close()

        print(f"\nThroughput Results:")
        print(f"  Send: {num_messages / send_time:.2f} msg/s")
        print(f"  Receive: {received / receive_time:.2f} msg/s")


