    def test_no_message_loss(
        self, client: pulsar.Client, producer: pulsar.Producer
    ):
        """Test that no messages are lost"""
        # Send known number of messages
        num_messages = 50
        for i in range(num_messages):
            producer.send(f"no-loss-{i}".encode())

        # Receive with multiple consumers
        consumers = []
        for i in range(3):
            c = client.subscribe(
                TEST_TOPIC,
                f"{TEST_SUBSCRIPTION}-noloss",
                consumer_type=pulsar.ConsumerType.${consumer_type}
            )
            consumers.append(c)

        # Collect all messages
        all_messages = set()
        for consumer in consumers:
            try:
                while True:
                    msg = consumer.receive(timeout_millis=2000)
                    all_messages.add(msg.data().decode())
                    consumer.acknowledge(msg)
            except Exception:
                pass

        for c in consumers:
            c.close()

        # Verify no loss
        assert len(all_messages) == num_messages


